{
  "family": "lks-leantime-app",
  "taskRoleArn": "arn:aws:iam::105778548542:role/LabRole",
  "executionRoleArn": "arn:aws:iam::105778548542:role/LabRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",

  "volumes": [
    {
      "name": "public_userfiles",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0e80cb97614677c68",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-02238570e58cbd00a",
          "iam": "DISABLED"
        }
      }
    },
    {
      "name": "userfiles",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0e80cb97614677c68",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-0881b51a06bc5e52e",
          "iam": "DISABLED"
        }
      }
    },
    {
      "name": "plugins",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0e80cb97614677c68",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-0ac7a94f21c6b24c5",
          "iam": "DISABLED"
        }
      }
    }
  ],

  "placementConstraints": [],

  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },

  "enableFaultInjection": false,

  "containerDefinitions": [
    {
      "name": "leantime",
      "image": "<task-def-image>",
      "cpu": 0,
      "essential": true,

      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],

      "environment": [
        {
          "name": "APP_URL",
          "value": "http://lks-oss-lb-1142196583.us-east-1.elb.amazonaws.com"
        },
        {
          "name": "APP_PORT",
          "value": "80"
        },
        {
          "name": "APP_NAME",
          "value": "lks-leantime-app"
        },
        {
          "name": "APP_TIMEZONE",
          "value": "Asia/Jakarta"
        },
        {
          "name": "APP_DEBUG",
          "value": "false"
        }
      ],

      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:ssm:us-east-1:105778548542:parameter/lks/db/host"
        },
        {
          "name": "DB_PORT",
          "valueFrom": "arn:aws:ssm:us-east-1:105778548542:parameter/lks/db/port"
        },
        {
          "name": "DB_DATABASE",
          "valueFrom": "arn:aws:ssm:us-east-1:105778548542:parameter/lks/db/name"
        },
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:ssm:us-east-1:105778548542:parameter/lks/db/username"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:ssm:us-east-1:105778548542:parameter/lks/db/password"
        }
      ],

      "mountPoints": [
        {
          "sourceVolume": "public_userfiles",
          "containerPath": "/var/www/html/public/userfiles",
          "readOnly": false
        },
        {
          "sourceVolume": "userfiles",
          "containerPath": "/var/www/html/userfiles",
          "readOnly": false
        },
        {
          "sourceVolume": "plugins",
          "containerPath": "/var/www/html/app/Plugins",
          "readOnly": false
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lks/leantime-app",
          "awslogs-region": "us-east-1",
          "mode": "non-blocking",
          "awslogs-create-group": "true",
          "max-buffer-size": "25m",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
